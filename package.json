{
  "name": "league-account-switcher",
  "version": "1.0.18",
  "description": "League Account Switcher",
  "author": "Jonas Merforth",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "release": "electron-builder --publish always",
    "fix-electron": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/fix-electron.ps1"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.merforth.league-account-switcher",
    "productName": "League Account Switcher",
    "copyright": "Copyright © 2026 Jonas Merforth",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "compression": "maximum",
    "afterPack": "build/afterPack.cjs",
    "publish": [
      {
        "provider": "github",
        "owner": "Jonas-Merforth",
        "repo": "league-account-switcher",
        "releaseType": "release"
      }
    ],
    "files": [
      "src/**/*",
      "!**/*.test.js",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${name}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "League Account Switcher"
    }
  }
}
